{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://orvit.app",
        "EXPO_PUBLIC_PUSHER_KEY": "5142e3a6de2a3aa1c543",
        "EXPO_PUBLIC_PUSHER_CLUSTER": "sa1"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://orvit.app",
        "EXPO_PUBLIC_PUSHER_KEY": "5142e3a6de2a3aa1c543",
        "EXPO_PUBLIC_PUSHER_CLUSTER": "sa1"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-services.json",
        "track": "internal"
      }
    }
  }
}
